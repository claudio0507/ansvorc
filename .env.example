# Copie este arquivo para .env e ajuste os valores antes do primeiro deploy.
# NUNCA commite o .env real — ele já está no .gitignore.

# ── Banco de dados ─────────────────────────────────────────────────────────────
# SQLite (desenvolvimento local, sem Docker):
DATABASE_URL=sqlite:///./sinalys.db

# PostgreSQL (produção / Docker Compose):
# DATABASE_URL=postgresql://sinalys:SENHA_FORTE@db:5432/sinalys
DB_PASSWORD=troque-por-senha-forte

# ── Segurança ──────────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=troque-por-secret-de-pelo-menos-32-caracteres

# ── Usuários iniciais (opcionais; se não definidos, senhas são geradas) ────────
ADMIN_EMAIL=admin@altanoroeste.com.br
ADMIN_PASSWORD=
PARAM_EMAIL=param@altanoroeste.com.br
PARAM_PASSWORD=
ORC_EMAIL=orc@altanoroeste.com.br
ORC_PASSWORD=

# ── App ────────────────────────────────────────────────────────────────────────
APP_VERSION=1.0.0
DEBUG=false
