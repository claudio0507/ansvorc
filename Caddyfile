sinalys.altanoroeste.com.br {
    # Auto HTTPS via Let's Encrypt
    reverse_proxy app:8000

    # Cabeçalhos de segurança
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        # script-src inclui 'unsafe-inline': o SPA React Router injeta scripts inline
        # de hidratação/stream no index.html. style-src já permitia inline (Tailwind/shadcn).
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        -Server
    }

    # Compressão
    encode gzip

    # Log de acesso
    log {
        output file /var/log/caddy/sinalys.log {
            roll_size 10mb
            roll_keep 5
        }
    }
}
